---
// Hero: centered terminal-style intro over a mouse-reactive dot-sphere canvas
// (faithful port of the seltz.ai hero animation: a slowly rotating Fibonacci
// sphere of teal dots, denser toward the bottom so it reads as a horizon.
// Dots near the cursor get pushed away with a slight swirl, brighten, and
// link up with short lines). The site-wide drifting specs live in Particles.astro.
---

<section class="hero relative overflow-hidden border-b border-slate-800">
  <canvas id="hero-sphere" class="pointer-events-none absolute inset-0 h-full w-full" aria-hidden="true"
  ></canvas>

  <div
    class="container relative z-10 mx-auto flex flex-col items-center gap-5 px-4 py-16 text-center sm:px-6 md:py-24 lg:px-8"
  >
    <span
      class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-white/5 px-3 py-1 text-xs text-gray-400 backdrop-blur-sm"
    >
      <span class="hero-status-dot h-2 w-2 rounded-full"></span>
      Distributed Systems Engineer @ Exein
    </span>

    <div class="font-mono">
      <p class="mb-2 text-sm text-gray-500">
        <span class="text-green-500">dominik</span><span class="text-gray-600">@</span><span
          class="text-teal-300">polzer</span
        ><span class="text-gray-600">:~$</span> whoami
      </p>
      <h1 class="text-4xl font-bold leading-tight text-green-500 sm:text-5xl">Dominik Polzer</h1>
      <p class="mx-auto mt-3 max-w-md text-base text-gray-400 sm:text-lg">
        10+ years building distributed systems — Rust, .NET and applied AI.<span
          class="hero-cursor text-green-500">▊</span
        >
      </p>
    </div>

    <div class="mt-1 flex flex-wrap justify-center gap-3 font-mono text-sm">
      <a
        href="/about"
        class="bg-green-500 px-4 py-2 font-semibold text-black transition-colors hover:bg-green-400"
      >
        cd ./about
      </a>
      <a
        href="/blog"
        class="border border-green-500 px-4 py-2 text-green-500 transition-colors hover:bg-green-500/10"
      >
        ls ./posts
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    /* subtle horizon glow behind the intro, echoing the reference design */
    background-image: radial-gradient(
      ellipse 70% 55% at 50% 110%,
      rgba(107, 236, 205, 0.07),
      rgba(34, 197, 94, 0.035) 45%,
      transparent 70%
    );
  }
  .hero-status-dot {
    background-color: rgb(107, 236, 205);
    box-shadow: 0 0 8px rgba(107, 236, 205, 0.8);
    animation: hero-pulse 2.4s ease-in-out infinite;
  }
  .hero-cursor {
    animation: hero-blink 1.1s steps(2, start) infinite;
  }
  @keyframes hero-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.35;
    }
  }
  @keyframes hero-blink {
    to {
      visibility: hidden;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-status-dot,
    .hero-cursor {
      animation: none;
    }
  }
</style>

<script>
  // Port of the seltz.ai hero canvas (constants match the original bundle).
  const canvas = document.getElementById("hero-sphere") as HTMLCanvasElement | null;
  const ctx = canvas?.getContext("2d");

  if (canvas && ctx) {
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const coarsePointer = window.matchMedia("(hover: none), (pointer: coarse)").matches;

    const COLOR = "107, 236, 205"; // #6BECCD
    const COUNT = 3600;
    const R = 125;
    const Z_OFFSET = 320;
    const FOV = 800;
    const DEPTH_DEN = 445;
    const ROT_SPEED = 4e-4;
    const FORCE_RADIUS = 140;
    const HOVER_RADIUS = 65;
    const LINK_RADIUS = 40;
    const MAX_OFFSET = 28;

    // seeded RNG so the sphere looks identical on every load
    const mulberry = (seed: number) => () => {
      let t = (seed += 1831565813);
      t = Math.imul(t ^ (t >>> 15), t | 1);
      t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
    const rand = mulberry(1337);
    const clamp01 = (v: number) => Math.max(0, Math.min(1, v));
    const smooth = (v: number) => v * v * (3 - 2 * v);
    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

    type Dot = {
      x: number; y: number; z: number;
      keep: boolean; sizeJitter: number;
      sx: number; sy: number; depth: number; hover: number;
      ox: number; oy: number; vx: number; vy: number;
    };

    // Fibonacci sphere, denser toward the bottom (horizon effect)
    const GOLDEN = Math.PI * (3 - Math.sqrt(5));
    const dots: Dot[] = [];
    for (let i = 0; i < COUNT; i++) {
      const t = 1 - (i / (COUNT - 1)) * 2;
      const rad = Math.sqrt(Math.max(0, 1 - t * t));
      const theta = GOLDEN * i;
      let x = Math.cos(theta) * rad + (rand() - 0.5) * (0.65 / R);
      let z = Math.sin(theta) * rad + (rand() - 0.5) * (0.65 / R);
      const n = Math.sqrt(x * x + t * t + z * z) || 1;
      x /= n;
      z /= n;
      // denser toward the bottom of the sphere (screen-down = +y)
      const keepProb = lerp(0.15, 0.98, smooth(clamp01((t + 1) / 2)));
      dots.push({
        x: x * R, y: t * R, z: z * R,
        keep: rand() < keepProb,
        sizeJitter: 0.4 + rand() ** 2 * 3.0,
        sx: 0, sy: 0, depth: 0, hover: 0,
        ox: 0, oy: 0, vx: 0, vy: 0,
      });
    }

    let width = 0;
    let height = 0;
    const resize = () => {
      const rect = canvas.getBoundingClientRect();
      const dpr = Math.max(1, window.devicePixelRatio || 1);
      if (rect.width <= 1 || rect.height <= 1) return;
      width = Math.floor(rect.width);
      height = Math.floor(rect.height);
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    resize();
    new ResizeObserver(resize).observe(canvas);

    let mx: number | null = null;
    let my: number | null = null;
    const trackPointer = (e: PointerEvent) => {
      const rect = canvas.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      if (x < 0 || y < 0 || x > rect.width || y > rect.height) {
        mx = my = null;
        return;
      }
      mx = x;
      my = y;
    };
    const clearPointer = () => (mx = my = null);
    if (!coarsePointer) {
      window.addEventListener("pointermove", trackPointer, { passive: true });
      window.addEventListener("pointercancel", clearPointer);
      window.addEventListener("blur", clearPointer);
    }

    let angle = 0;
    let rafId = 0;
    let visible = true;

    const drawFrame = () => {
      ctx.clearRect(0, 0, width, height);
      const cx = width / 2;
      const cy = height * 0.62; // sphere sits low so the top arc frames the text
      // scale with viewport so the sphere breaks out of the text container
      const fov = FOV * Math.min(1.75, Math.max(0.55, width / 820));
      const hovered: Dot[] = [];

      for (const p of dots) {
        p.hover = 0;
        if (!p.keep) continue;
        const cos = Math.cos(angle);
        const sin = Math.sin(angle);
        const rx = p.x * cos - p.z * sin;
        const rz = p.x * sin + p.z * cos;
        const zc = rz + Z_OFFSET;
        if (zc <= 1) continue;
        const scale = fov / zc;
        p.sx = rx * scale + cx;
        p.sy = p.y * scale + cy;
        p.depth = 1 - Math.min(1, Math.max(0, zc / DEPTH_DEN));

        // push away from the cursor with a slight tangential swirl
        let tx = 0;
        let ty = 0;
        if (mx != null && my != null) {
          const dx = p.sx - mx;
          const dy = p.sy - my;
          const d = Math.sqrt(dx * dx + dy * dy) || 1;
          if (d < HOVER_RADIUS) {
            p.hover = smooth(1 - d / HOVER_RADIUS);
            hovered.push(p);
          }
          if (d < FORCE_RADIUS) {
            const s = smooth(1 - d / FORCE_RADIUS);
            const nx = dx / d;
            const ny = dy / d;
            const f = 30 * s * (0.35 + 0.65 * p.depth);
            tx = nx * f + -ny * f * 0.25;
            ty = ny * f + nx * f * 0.25;
          }
        }
        p.vx = (p.vx + (tx - p.ox) * 0.1) * 0.2;
        p.vy = (p.vy + (ty - p.oy) * 0.1) * 0.2;
        p.ox = Math.max(-MAX_OFFSET, Math.min(MAX_OFFSET, p.ox + p.vx));
        p.oy = Math.max(-MAX_OFFSET, Math.min(MAX_OFFSET, p.oy + p.vy));
      }

      // link hovered dots that are close to each other
      for (let i = 0; i < hovered.length; i++) {
        const a = hovered[i];
        const ax = a.sx + a.ox;
        const ay = a.sy + a.oy;
        for (let j = i + 1; j < hovered.length; j++) {
          const b = hovered[j];
          const bx = b.sx + b.ox;
          const by = b.sy + b.oy;
          const dx = ax - bx;
          const dy = ay - by;
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d > LINK_RADIUS) continue;
          const alpha = (1 - d / LINK_RADIUS) * Math.min(a.hover, b.hover);
          ctx.strokeStyle = `rgba(${COLOR}, ${0.48 * alpha})`;
          ctx.lineWidth = 0.6;
          ctx.beginPath();
          ctx.moveTo(ax, ay);
          ctx.lineTo(bx, by);
          ctx.stroke();
        }
      }

      for (const p of dots) {
        if (!p.keep) continue;
        const alpha = clamp01(0.045 + 0.18 * p.depth + p.hover * 0.31);
        const radius =
          Math.max(0.55, 1.05 * (0.9 + p.depth)) * p.sizeJitter * (1 + p.hover * 0.18);
        ctx.beginPath();
        ctx.fillStyle = `rgba(${COLOR}, ${alpha})`;
        ctx.arc(p.sx + p.ox, p.sy + p.oy, radius, 0, Math.PI * 2);
        ctx.fill();
      }
    };

    const tick = () => {
      drawFrame();
      angle += ROT_SPEED;
      rafId = requestAnimationFrame(tick);
    };
    const start = () => {
      if (!rafId && !reducedMotion) rafId = requestAnimationFrame(tick);
    };
    const stop = () => {
      cancelAnimationFrame(rafId);
      rafId = 0;
    };

    new IntersectionObserver(([entry]) => {
      visible = entry.isIntersecting;
      visible ? start() : stop();
    }).observe(canvas);

    if (reducedMotion) drawFrame();
    else if (visible) start();
  }
</script>
