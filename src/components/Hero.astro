---
// Hero: centered terminal-style intro. The animated page background lives in
// Particles.astro; this section stays transparent so it shows through.
---

<section class="hero relative border-b border-slate-800">
  <div
    class="container mx-auto flex flex-col items-center gap-5 px-4 py-16 text-center sm:px-6 md:py-24 lg:px-8"
  >
    <span
      class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-white/5 px-3 py-1 text-xs text-gray-400 backdrop-blur-sm"
    >
      <span class="hero-status-dot h-2 w-2 rounded-full"></span>
      Distributed Systems Engineer @ Exein
    </span>

    <div class="font-mono">
      <p class="mb-2 text-sm text-gray-500">
        <span class="text-green-500">dominik</span><span class="text-gray-600">@</span><span
          class="text-teal-300">polzer</span
        ><span class="text-gray-600">:~$</span> whoami
      </p>
      <h1 class="text-4xl font-bold leading-tight text-green-500 sm:text-5xl">Dominik Polzer</h1>
      <p class="mx-auto mt-3 max-w-md text-base text-gray-400 sm:text-lg">
        10+ years building distributed systems — Rust, .NET and applied AI.<span
          class="hero-cursor text-green-500">▊</span
        >
      </p>
    </div>

    <div class="mt-1 flex flex-wrap justify-center gap-3 font-mono text-sm">
      <a
        href="/about"
        class="bg-green-500 px-4 py-2 font-semibold text-black transition-colors hover:bg-green-400"
      >
        cd ./about
      </a>
      <a
        href="/blog"
        class="border border-green-500 px-4 py-2 text-green-500 transition-colors hover:bg-green-500/10"
      >
        ls ./posts
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    /* subtle horizon glow behind the intro, echoing the reference design */
    background-image: radial-gradient(
      ellipse 70% 55% at 50% 110%,
      rgba(107, 236, 205, 0.07),
      rgba(34, 197, 94, 0.035) 45%,
      transparent 70%
    );
  }
  .hero-status-dot {
    background-color: rgb(107, 236, 205);
    box-shadow: 0 0 8px rgba(107, 236, 205, 0.8);
    animation: hero-pulse 2.4s ease-in-out infinite;
  }
  .hero-cursor {
    animation: hero-blink 1.1s steps(2, start) infinite;
  }
  @keyframes hero-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.35;
    }
  }
  @keyframes hero-blink {
    to {
      visibility: hidden;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-status-dot,
    .hero-cursor {
      animation: none;
    }
  }
</style>
