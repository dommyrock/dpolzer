---
// Full-page background particle field, modeled on the seltz.ai canvas:
// ~240 tiny dots (fixed size, no links, no pointer interaction) drifting
// slowly at half opacity over the page background.
---

<canvas
  id="page-particles"
  class="pointer-events-none fixed inset-0 z-0 h-full w-full"
  aria-hidden="true"></canvas>

<script>
  const canvas = document.getElementById("page-particles") as HTMLCanvasElement | null;
  const ctx = canvas?.getContext("2d");

  if (canvas && ctx) {
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    type Particle = { x: number; y: number; r: number; vx: number; vy: number; color: string };

    let particles: Particle[] = [];
    let width = 0;
    let height = 0;
    let rafId = 0;

    const spawn = () => {
      const count = Math.min(240, Math.floor((width * height) / 6000));
      particles = Array.from({ length: count }, () => {
        const angle = Math.random() * Math.PI * 2;
        const speed = 0.1 + Math.random() * 0.25;
        return {
          x: Math.random() * width,
          y: Math.random() * height,
          r: 0.7 + Math.random() * 0.7,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed,
          // mostly white like the reference, with a light green/teal accent
          color:
            Math.random() < 0.75
              ? "rgba(255,255,255,0.5)"
              : Math.random() < 0.5
                ? "rgba(107,236,205,0.5)"
                : "rgba(34,197,94,0.5)",
        };
      });
    };

    const drawFrame = () => {
      ctx.clearRect(0, 0, width, height);
      for (const p of particles) {
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = p.color;
        ctx.fill();
      }
    };

    const tick = () => {
      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < -4) p.x = width + 4;
        if (p.x > width + 4) p.x = -4;
        if (p.y < -4) p.y = height + 4;
        if (p.y > height + 4) p.y = -4;
      }
      drawFrame();
      rafId = requestAnimationFrame(tick);
    };

    const resize = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      spawn();
      if (reducedMotion) drawFrame();
    };

    let resizeTimer = 0;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(resize, 150);
    });

    resize();
    if (!reducedMotion) rafId = requestAnimationFrame(tick);
  }
</script>
